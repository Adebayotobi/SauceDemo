{
  "name": "demo_assessment",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "cypress run",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:login": "cypress run --spec cypress/e2e/auth/login.cy.js",
    "cy:run:inventory": "cypress run --spec cypress/e2e/inventory/inventory.cy.js",
    "cy:run:checkout": "cypress run --spec cypress/e2e/checkout/checkout.cy.js",
    "cy:report": "npm run cy:run && npm run report:merge && npm run report:generate",
    "report:merge": "mochawesome-merge cypress/reports/mocha/*.json -o cypress/reports/mocha/merged.json",
    "report:generate": "marge cypress/reports/mocha/merged.json --reportDir cypress/reports/html --inline"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "cypress": "^15.11.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}
